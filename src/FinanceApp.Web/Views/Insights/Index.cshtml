@model FinanceApp.Web.Models.Insights.InsightsPageViewModel
@{
    ViewData["Title"] = "Insights";
}
<h1 class="h4 mb-3">Insights financeiros</h1>
<div class="row g-3">
@foreach (var i in Model.Items)
{
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h6>@i.Title</h6>
                <p class="mb-0">@i.Description</p>
            </div>
        </div>
    </div>
}
</div>
