@{
    ViewData["Title"] = "Lançamentos";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="h4">Lançamentos</h2>
    <button class="btn btn-primary">Novo lançamento</button>
</div>
<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>Data</th>
                        <th>Descrição</th>
                        <th>Categoria</th>
                        <th class="text-end">Valor</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="4" class="text-center text-muted">Sem dados por enquanto. A Fase 3 implementará o CRUD completo.</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
