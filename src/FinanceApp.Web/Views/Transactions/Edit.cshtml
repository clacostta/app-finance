@model FinanceApp.Web.Models.Transactions.TransactionFormViewModel
@using FinanceApp.Domain.Enums
@{ ViewData["Title"] = "Editar lançamento"; var accounts = (IEnumerable<dynamic>)ViewBag.Accounts; var cards=(IEnumerable<dynamic>)ViewBag.CreditCards; var categories=(IEnumerable<dynamic>)ViewBag.Categories; }
<h1 class="h4 mb-3">Editar lançamento</h1>
<form method="post" class="card card-body">@Html.AntiForgeryToken()<input asp-for="Id" type="hidden"/><div asp-validation-summary="ModelOnly" class="text-danger"></div>
<div class="row g-2"><div class="col-md-3"><label asp-for="TransactionDate" class="form-label"></label><input asp-for="TransactionDate" type="date" class="form-control"/></div><div class="col-md-3"><label asp-for="Type" class="form-label"></label><select asp-for="Type" class="form-select">@foreach(var t in Enum.GetValues<TransactionType>()){<option value="@t">@t</option>}</select></div><div class="col-md-3"><label asp-for="Amount" class="form-label"></label><input asp-for="Amount" class="form-control"/></div><div class="col-md-3"><label asp-for="CategoryId" class="form-label">Categoria</label><select asp-for="CategoryId" class="form-select"><option value="">--</option>@foreach(var c in categories){<option value="@c.Id">@c.Name</option>}</select></div></div>
<div class="mt-2"><label asp-for="Description" class="form-label"></label><input asp-for="Description" class="form-control"/></div>
<div class="row g-2 mt-1"><div class="col-md-6"><label asp-for="AccountId" class="form-label">Conta</label><select asp-for="AccountId" class="form-select"><option value="">--</option>@foreach(var a in accounts){<option value="@a.Id">@a.Name</option>}</select></div><div class="col-md-6"><label asp-for="CreditCardId" class="form-label">Cartão</label><select asp-for="CreditCardId" class="form-select"><option value="">--</option>@foreach(var c in cards){<option value="@c.Id">@c.Name</option>}</select></div></div>
<div class="mt-2"><label asp-for="Notes" class="form-label"></label><textarea asp-for="Notes" class="form-control"></textarea></div>
<div class="form-check my-3"><input asp-for="IsRecurring" class="form-check-input"/><label asp-for="IsRecurring" class="form-check-label">Recorrente</label></div>
<button class="btn btn-primary" type="submit">Salvar alterações</button></form>
