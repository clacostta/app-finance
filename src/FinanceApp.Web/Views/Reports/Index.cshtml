@model FinanceApp.Web.Models.Reports.ReportsPageViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Relatórios";
    var labels = JsonSerializer.Serialize(Model.Bundle.ExpenseByCategory.Select(x => x.Label));
    var values = JsonSerializer.Serialize(Model.Bundle.ExpenseByCategory.Select(x => x.Total));
}
<div class="d-flex justify-content-between align-items-center mb-3"><h1 class="h4">Relatórios</h1></div>
<form method="get" class="row g-2 mb-3"><div class="col-md-4"><input type="date" name="from" value="@Model.From.ToString("yyyy-MM-dd")" class="form-control" /></div><div class="col-md-4"><input type="date" name="to" value="@Model.To.ToString("yyyy-MM-dd")" class="form-control" /></div><div class="col-md-4"><button class="btn btn-outline-primary w-100">Atualizar</button></div></form>
<div class="row g-3">
<div class="col-lg-6"><div class="card"><div class="card-body"><h6>Gastos por categoria</h6><canvas id="reportCategoryChart" height="160"></canvas></div></div></div>
<div class="col-lg-6"><div class="card"><div class="card-body"><h6>Top despesas por descrição</h6><ul class="mb-0">@foreach(var i in Model.Bundle.TopExpenseDescriptions){<li>@i.Label - @i.Total.ToString("C")</li>}</ul></div></div></div>
<div class="col-lg-6"><div class="card"><div class="card-body"><h6>Receitas por mês</h6><ul class="mb-0">@foreach(var i in Model.Bundle.IncomeByMonth){<li>@i.Label - @i.Total.ToString("C")</li>}</ul></div></div></div>
<div class="col-lg-6"><div class="card"><div class="card-body"><h6>Despesas por mês</h6><ul class="mb-0">@foreach(var i in Model.Bundle.ExpenseByMonth){<li>@i.Label - @i.Total.ToString("C")</li>}</ul></div></div></div>
</div>
@section Scripts {
<script>
new Chart(document.getElementById('reportCategoryChart'), { type:'pie', data:{ labels:@Html.Raw(labels), datasets:[{ data:@Html.Raw(values) }] } });
</script>
}
