@model IReadOnlyCollection<FinanceApp.Application.DTOs.Subscriptions.SubscriptionDto>
@{ ViewData["Title"] = "Assinaturas"; }
<div class="d-flex justify-content-between align-items-center mb-3"><h1 class="h4">Painel de assinaturas</h1><form asp-action="Refresh" method="post">@Html.AntiForgeryToken()<button class="btn btn-outline-primary">Atualizar detecção</button></form></div>
<div class="card"><div class="card-body"><table class="table table-striped"><thead><tr><th>Serviço</th><th class="text-end">Média mensal</th><th class="text-end">Projeção anual</th><th>Ocorrências</th><th>Status</th><th></th></tr></thead><tbody>
@foreach(var i in Model){
<tr><td>@i.Merchant</td><td class="text-end">@i.AverageAmount.ToString("C")</td><td class="text-end">@i.AnnualProjection.ToString("C")</td><td>@i.OccurrenceCount</td><td>@(i.IsActive?"Ativa":"Inativa")</td><td class="text-end">@if(i.IsActive){<form asp-action="Deactivate" method="post" class="d-inline">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@i.Id"/><button class="btn btn-sm btn-outline-danger">Desativar</button></form>}</td></tr>
}
</tbody></table></div></div>
