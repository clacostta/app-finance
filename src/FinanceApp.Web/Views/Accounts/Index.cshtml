@model IReadOnlyCollection<FinanceApp.Application.DTOs.Accounts.AccountDto>
@{
    ViewData["Title"] = "Contas";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h4">Contas bancárias</h1>
    <a asp-action="Create" class="btn btn-primary">Nova conta</a>
</div>
<div class="card"><div class="card-body"><table class="table table-striped">
<thead><tr><th>Nome</th><th>Instituição</th><th class="text-end">Saldo Inicial</th><th>Status</th><th></th></tr></thead>
<tbody>
@foreach (var i in Model) {
<tr>
<td>@i.Name</td><td>@i.FinancialInstitutionName</td><td class="text-end">@i.InitialBalance.ToString("C")</td><td>@(i.IsActive?"Ativa":"Inativa")</td>
<td class="text-end"><a asp-action="Edit" asp-route-id="@i.Id" class="btn btn-sm btn-outline-primary">Editar</a>
<form asp-action="Delete" asp-route-id="@i.Id" method="post" class="d-inline">@Html.AntiForgeryToken()<button class="btn btn-sm btn-outline-danger">Excluir</button></form></td>
</tr>
}
</tbody></table></div></div>
