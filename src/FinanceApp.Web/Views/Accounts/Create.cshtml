@model FinanceApp.Web.Models.Accounts.AccountFormViewModel
@{ ViewData["Title"] = "Nova conta"; var institutions = (IEnumerable<dynamic>)ViewBag.Institutions; }
<h1 class="h4 mb-3">Nova conta</h1>
<form method="post" class="card card-body">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-2"><label asp-for="Name" class="form-label"></label><input asp-for="Name" class="form-control" /></div>
    <div class="mb-2"><label asp-for="FinancialInstitutionId" class="form-label">Instituição</label><select asp-for="FinancialInstitutionId" class="form-select">@foreach(var i in institutions){<option value="@i.Id">@i.Name</option>}</select></div>
    <div class="mb-2"><label asp-for="InitialBalance" class="form-label"></label><input asp-for="InitialBalance" class="form-control" /></div>
    <div class="form-check mb-3"><input asp-for="IsActive" class="form-check-input"/><label asp-for="IsActive" class="form-check-label">Ativa</label></div>
    <button class="btn btn-primary" type="submit">Salvar</button>
</form>
