@model IReadOnlyCollection<FinanceApp.Application.DTOs.Goals.GoalDto>
@{ ViewData["Title"] = "Metas"; }
<div class="d-flex justify-content-between align-items-center mb-3"><h1 class="h4">Metas financeiras</h1><a asp-action="Create" class="btn btn-primary">Nova meta</a></div>
<div class="row g-3">
@foreach (var i in Model){
<div class="col-md-6"><div class="card"><div class="card-body"><h6>@i.Name</h6><p class="mb-1">@i.CurrentAmount.ToString("C") / @i.TargetAmount.ToString("C")</p><div class="progress mb-2"><div class="progress-bar" role="progressbar" style="width:@Math.Min(i.ProgressPercent,100)%"></div></div><small class="text-muted">Meta: @i.ProgressPercent.ToString("N1")%</small><div class="mt-2"><a asp-action="Edit" asp-route-id="@i.Id" class="btn btn-sm btn-outline-primary">Editar</a><form asp-action="Delete" method="post" class="d-inline">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@i.Id"/><button class="btn btn-sm btn-outline-danger">Excluir</button></form></div></div></div></div>
}
</div>
