<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FinanceApp</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<header class="border-bottom bg-white">
    <nav class="container navbar navbar-expand-lg">
        <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">FinanceApp</a>
        <div class="collapse navbar-collapse show">
            <ul class="navbar-nav me-auto">
                <li class="nav-item"><a class="nav-link" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                <li class="nav-item"><a class="nav-link" asp-controller="Transactions" asp-action="Index">Lançamentos</a></li>
                <li class="nav-item"><a class="nav-link" asp-controller="Imports" asp-action="Index">Importação OFX</a></li>
            </ul>
            <div>
                @if (User.Identity?.IsAuthenticated ?? false)
                {
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger btn-sm">Sair</button>
                    </form>
                }
                else
                {
                    <a class="btn btn-outline-primary btn-sm" asp-controller="Account" asp-action="Login">Entrar</a>
                }
            </div>
        </div>
    </nav>
</header>
<main class="container py-4">
    @RenderBody()
</main>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
