<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FinanceApp</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<div class="app-shell">
    <aside class="app-sidebar" id="appSidebar">
        <div class="sidebar-brand">
            <a class="text-decoration-none" asp-controller="Home" asp-action="Index">
                <span class="brand-badge"><i class="bi bi-wallet2"></i></span>
                <span class="brand-text">FinanceApp</span>
            </a>
        </div>

        <nav class="sidebar-nav">
            <a class="nav-item" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2"></i> Dashboard</a>
            <a class="nav-item" asp-controller="Transactions" asp-action="Index"><i class="bi bi-arrow-left-right"></i> Lançamentos</a>
            <a class="nav-item" asp-controller="Accounts" asp-action="Index"><i class="bi bi-bank"></i> Contas</a>
            <a class="nav-item" asp-controller="CreditCards" asp-action="Index"><i class="bi bi-credit-card-2-front"></i> Cartões</a>
            <a class="nav-item" asp-controller="Categories" asp-action="Index"><i class="bi bi-tags"></i> Categorias</a>
            <a class="nav-item" asp-controller="Budgets" asp-action="Index"><i class="bi bi-pie-chart"></i> Orçamentos</a>
            <a class="nav-item" asp-controller="Goals" asp-action="Index"><i class="bi bi-bullseye"></i> Metas</a>
            <a class="nav-item" asp-controller="Subscriptions" asp-action="Index"><i class="bi bi-arrow-repeat"></i> Assinaturas</a>
            <a class="nav-item" asp-controller="Notifications" asp-action="Index"><i class="bi bi-bell"></i> Alertas</a>
            <a class="nav-item" asp-controller="Insights" asp-action="Index"><i class="bi bi-lightbulb"></i> Insights</a>
            <a class="nav-item" asp-controller="Reports" asp-action="Index"><i class="bi bi-bar-chart"></i> Relatórios</a>
            <a class="nav-item" asp-controller="Imports" asp-action="Index"><i class="bi bi-upload"></i> Importação OFX</a>
        </nav>
    </aside>

    <div class="app-content">
        <header class="app-topbar">
            <button id="sidebarToggle" class="btn btn-outline-secondary d-lg-none" type="button" aria-label="Abrir menu">
                <i class="bi bi-list"></i>
            </button>

            <div class="page-title">
                <h1>@(ViewData["Title"] ?? "FinanceApp")</h1>
            </div>

            <div class="d-flex align-items-center gap-2">
                @if (User.Identity?.IsAuthenticated ?? false)
                {
                    <span class="badge text-bg-light border">@User.Identity?.Name</span>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-box-arrow-right"></i> Sair</button>
                    </form>
                }
                else
                {
                    <a class="btn btn-sm btn-primary" asp-controller="Account" asp-action="Login"><i class="bi bi-box-arrow-in-right"></i> Entrar</a>
                }
            </div>
        </header>

        <main class="app-main">
            <div class="content-surface">
                @RenderBody()
            </div>
        </main>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
